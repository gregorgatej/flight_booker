<h1>Search Flights<h1>

<%= form_with url: flights_path, method: :get do %>
  <div>
    <%= label_tag :departure_airport_id, "Departure airport" %>
    <%= select_tag :departure_airport_id,
          options_from_collection_for_select(@airports, :id, :code, params[:departure_airport_id]),
          prompt: "Select departure airport" %>
  </div>

  <div>
    <%= label_tag :arrival_airport_id, "Arrival airport" %>
    <%= select_tag :arrival_airport_id,
          options_from_collection_for_select(@airports, :id, :code, params[:arrival_airport_id]),
          prompt: "Select arrival airport" %>
  </div>

  <div>
    <%=label_tag :date, "Date" %>
    <%= select_tag :date,
          options_for_select(@flight_dates.map { |d| [d.strftime("%Y-%m-%d"), d.to_s] }, params[:date]),
          prompt: "Select date" %>
  </div>

  <div>
    <%= label_tag :num_passengers, "Passengers" %>
    <%= select_tag :num_passengers,
          options_for_select((1..4).to_a, params[:num_passengers]),
          prompt: "Select passengers" %>
  </div>

  <%= submit_tag "Search" %>
<% end %>

<% if @matching_flights.any? %>
  <h2>Available Flights</h2>

  <%= form_with url: new_booking_path, method: :get do %>
    <% @matching_flights.each do |flight| %>
      <div>
        <%= radio_button_tag :flight_id, flight.id %>
        <%= label_tag "flight_id_#{flight.id}" do %>
          <strong><%= flight.departure_airport.code %> → <%= flight.arrival_airport.code %></strong>
          |
          <%= flight.start_datetime.strftime("%Y-%m-%d %H:%M") %>
          |
          <%= flight.duration_minutes %> minutes
          |
          $<%= flight.price_cents / 100.0 %>
        <% end %>
      </div>
    <% end %>

    <%= hidden_field_tag :num_passengers, params[:num_passengers] %>
    <%= submit_tag "Continue" %>
  <% end %>
<% elsif search_params_present? %>
  <p>No flights matched your search.</p>
<% end %>
